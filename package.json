{
  "name": "energymix-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "index.ts",
  "scripts": {
    "dev": "nodemon --watch \"src/**.*.ts\" --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node ./dist/index.js",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\""
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
